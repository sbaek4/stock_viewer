{
  "name": "realtime-stock-viewer",
  "private": true,
  "version": "1.0.0",
  "overrides": {
    "vitest": "2.1.9"
  },
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "build": "npm run build -w frontend && npm run typecheck -w backend",
    "test": "npm run test -w backend && npm run test -w frontend",
    "lint": "npm run lint -w frontend"
  }
}
